{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug mygame (lldb)",
      "type": "lldb",
      "request": "launch",
      // xmake's default output path per platform.
      // Adjust the arch (x86_64 / arm64) if it doesn't match your machine.
      "args": [],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "xmake: build",
      "linux": {
        "program": "${workspaceFolder}/build/linux/x86_64/debug/mygame"
      },
      "osx": {
        "program": "${workspaceFolder}/build/macosx/arm64/debug/mygame"
      },
      "windows": {
        "program": "${workspaceFolder}/build/windows/x86_64/debug/mygame.exe"
      }
    }
  ]
}