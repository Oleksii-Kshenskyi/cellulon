# Points clangd at the compile_commands.json that the xmake-vscode
# extension generates in .vscode/.
CompileFlags:
  CompilationDatabase: .

Diagnostics:
  UnusedIncludes: Strict
  ClangTidy:
    Add:
      - modernize-*
      - performance-*
      - readability-*
      - bugprone-*
    Remove:
      - modernize-use-trailing-return-type
      - readability-identifier-length
